@inherits LayoutComponentBase

<a class="skip-link" href="#auth-main">Skip to content</a>

<div class="auth-shell">
    <aside class="auth-brand" aria-hidden="true">
        <div class="auth-brand-inner">
            <span class="auth-brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                    <path d="m9 12 2 2 4-4" />
                </svg>
                Vault
            </span>

            <div>
                <h2>Your data, kept safe across every launch.</h2>
                <p>
                    Vault stores accounts in a SQL Server container backed by a persistent
                    volume, so everything you create survives a restart.
                </p>
                <ul class="auth-points">
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                        Persistent, named-volume storage
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                        Passwordless passkey sign-in
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                        Confirmed-email account security
                    </li>
                </ul>
            </div>

            <p class="auth-brand-foot">Built with Aspire · SQL Server persistent volume</p>
        </div>
    </aside>

    <main id="auth-main" class="auth-panel">
        <div class="auth-card">
            <span class="auth-card-brand">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                    <path d="m9 12 2 2 4-4" />
                </svg>
                Vault
            </span>
            @Body
        </div>
    </main>
</div>
