@page
@model OrleansVoting.Pages.ErrorModel

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <title>Something went wrong · Grain Poll</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link href="~/css/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>

<body>
    <main class="error-stage">
        <div class="error-card">
            <p class="error-eyebrow">Stage interrupted</p>
            <h1>Something went wrong</h1>
            <p class="error-lead">An error occurred while processing your request. Try heading back and starting a new poll.</p>

            @if (Model.ShowRequestId)
            {
                <p class="error-meta">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <a class="error-home" href="~/new">Back to Grain Poll</a>

            <p class="error-note">
                Swapping to the <strong>Development</strong> environment displays detailed information about the error.
                It shouldn't be enabled for deployed apps as it can expose sensitive information.
            </p>
        </div>
    </main>

    <style>
        .error-stage {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .error-card {
            width: min(560px, 100%);
            background: var(--surface);
            border: 1px solid var(--line);
            border-left: 5px solid var(--danger);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 2rem;
        }

        .error-eyebrow {
            font-family: var(--font-mono);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--danger-text);
            margin: 0 0 0.5rem;
        }

        .error-card h1 {
            margin: 0 0 0.75rem;
            font-size: clamp(1.8rem, 5vw, 2.4rem);
        }

        .error-lead {
            color: var(--ink-soft);
            margin: 0 0 1.25rem;
            line-height: 1.5;
        }

        .error-meta {
            font-size: 0.9rem;
            color: var(--ink-soft);
        }

        .error-meta code {
            font-family: var(--font-mono);
            color: var(--ink);
            background: var(--surface-2);
            border: 1px solid var(--line);
            border-radius: 7px;
            padding: 0.1rem 0.45rem;
        }

        .error-home {
            display: inline-flex;
            align-items: center;
            font-family: var(--font-display);
            font-weight: 700;
            color: var(--btn-ink);
            background: linear-gradient(110deg, var(--btn-bg), var(--btn-bg-2));
            border-radius: var(--radius-pill);
            padding: 0.75rem 1.4rem;
            text-decoration: none;
            margin: 0.5rem 0 1.5rem;
        }

        .error-note {
            font-size: 0.86rem;
            color: var(--ink-faint);
            margin: 0;
            line-height: 1.5;
        }
    </style>
</body>

</html>
