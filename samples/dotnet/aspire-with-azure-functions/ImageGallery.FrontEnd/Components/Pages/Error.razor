@page "/Error"
@using System.Diagnostics

<PageTitle>Error · Darkroom Studio</PageTitle>

<section class="intro">
    <p class="eyebrow">Overexposed</p>
    <h1 class="intro__title">Something didn't develop</h1>
    <p class="intro__lede">An error occurred while processing your request.</p>
</section>

@if (ShowRequestId)
{
    <p class="mono" style="color: var(--ink-muted);">
        Request ID: <code>@RequestId</code>
    </p>
}

<p style="color: var(--ink-soft); max-width: 60ch;">
    Swapping to the <strong>Development</strong> environment displays more detailed
    information about what went wrong. <strong>The Development environment shouldn't
    be enabled for deployed applications</strong>, because it can leak sensitive
    information from exceptions to end users. For local debugging, set the
    <code>ASPNETCORE_ENVIRONMENT</code> environment variable to <strong>Development</strong>
    and restart the app.
</p>

<p><a class="btn btn-ghost" href="">Back to the gallery</a></p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
