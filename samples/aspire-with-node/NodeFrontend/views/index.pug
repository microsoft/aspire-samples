//- The Aspire Almanac — a printed-almanac / newspaper rendering of the
//- weather forecast. Server-rendered with Pug & Express; pure CSS, no build
//- step. Decorative glyphs are inline SVG dingbats chosen by condition.
doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="color-scheme", content="light dark")
    meta(name="description", content="The Aspire Almanac — a five-day weather forecast rendered server-side with Express and Pug, served from an Aspire application with a Redis cache.")
    title The Aspire Almanac — Weather Forecast
    link(rel="icon", href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='%23f7f2e7'/%3E%3Ccircle cx='8' cy='8' r='3.4' fill='none' stroke='%238a1c1c' stroke-width='1.4'/%3E%3Cpath d='M8 .8v2.2M8 13v2.2M.8 8h2.2M13 8h2.2M2.8 2.8l1.6 1.6M11.6 11.6l1.6 1.6M13.2 2.8l-1.6 1.6M4.4 11.6l-1.6 1.6' stroke='%238a1c1c' stroke-width='1.2'/%3E%3C/svg%3E")
    style.
      :root {
        --paper: #f7f2e7;
        --panel: #fbf7ee;
        --ink: #1b1714;
        --ink-soft: #4d453b;
        --rule: #1b1714;
        --hair: #c5b89e;
        --accent: #8a1c1c;
        --stripe: #ece2cd;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #16130e;
          --panel: #1d1810;
          --ink: #f3ecdd;
          --ink-soft: #c3b9a6;
          --rule: #f3ecdd;
          --hair: #443a2b;
          --accent: #e6a9a9;
          --stripe: #211b13;
        }
      }
      * { box-sizing: border-box; }
      html { background: var(--paper); }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: Georgia, 'Iowan Old Style', 'Times New Roman', 'Times', serif;
        line-height: 1.55;
        font-size: 17px;
      }
      .visually-hidden {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
      }
      a { color: var(--ink); }
      .skip-link {
        position: absolute; left: 1rem; top: -4rem; z-index: 5;
        background: var(--ink); color: var(--paper);
        padding: 0.5rem 0.9rem; text-decoration: none;
        font-family: ui-sans-serif, system-ui, sans-serif; font-size: 0.85rem;
        letter-spacing: 0.04em; transition: top 0.15s ease;
      }
      .skip-link:focus { top: 1rem; outline: 3px solid var(--accent); outline-offset: 2px; }
      .paper {
        max-width: 70rem;
        margin: 0 auto;
        padding: clamp(1.25rem, 4vw, 3rem) clamp(1.25rem, 4vw, 3.5rem) 2.5rem;
      }
      /* Masthead */
      .masthead { text-align: center; }
      .masthead__kicker {
        font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 0.32em;
        font-size: 0.7rem; font-weight: 700; color: var(--ink-soft);
        border-bottom: 1px solid var(--hair); padding-bottom: 0.6rem; margin-bottom: 0.8rem;
      }
      .masthead__title {
        margin: 0.2rem 0 0.1rem;
        font-size: clamp(2.6rem, 8vw, 5rem);
        font-weight: 700; letter-spacing: -0.01em; line-height: 1.02;
      }
      .masthead__title em { font-style: italic; }
      .masthead__sub {
        margin: 0.3rem 0 0;
        font-style: italic; font-size: 1.1rem; color: var(--ink-soft);
      }
      .rule-double {
        border: 0; height: 0;
        border-top: 3px solid var(--rule); border-bottom: 1px solid var(--rule);
        margin: 1rem 0 0.5rem;
      }
      .dateline {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap;
        font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 0.12em;
        font-size: 0.68rem; font-weight: 600; color: var(--ink-soft);
        padding-bottom: 0.9rem; border-bottom: 3px double var(--rule);
        margin-bottom: 1.6rem;
      }
      .dateline svg { color: var(--accent); }
      /* Body grid */
      .edition {
        display: grid;
        grid-template-columns: 1.7fr 1fr;
        gap: 2.4rem;
        align-items: start;
      }
      .lead h2, .key h2 {
        font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 0.18em;
        font-size: 0.74rem; font-weight: 700; color: var(--ink-soft);
        margin: 0 0 0.6rem; padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--hair);
      }
      .standfirst { margin: 0 0 1rem; }
      .standfirst::first-letter {
        float: left; font-size: 3.4rem; line-height: 0.72;
        padding: 0.18rem 0.5rem 0 0; color: var(--accent); font-weight: 700;
      }
      .key ul { list-style: none; margin: 0; padding: 0; }
      .key li {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.35rem 0; border-bottom: 1px solid var(--hair);
        font-size: 0.95rem;
      }
      .key li:last-child { border-bottom: 0; }
      .key svg { color: var(--accent); flex: none; }
      .key b { font-weight: 700; }
      .key span { color: var(--ink-soft); }
      /* Forecast table */
      .forecast { margin-bottom: 1.8rem; }
      .forecast caption {
        text-align: left;
        font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 0.18em;
        font-size: 0.74rem; font-weight: 700; color: var(--ink-soft);
        margin-bottom: 0.6rem; padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--hair);
      }
      table.almanac { width: 100%; border-collapse: collapse; }
      table.almanac thead th {
        font-family: ui-sans-serif, system-ui, sans-serif;
        text-transform: uppercase; letter-spacing: 0.08em;
        font-size: 0.66rem; font-weight: 700; color: var(--ink-soft);
        text-align: left; padding: 0.35rem 0.6rem; border-bottom: 2px solid var(--rule);
      }
      table.almanac thead th.num, table.almanac td.num { text-align: right; font-variant-numeric: tabular-nums; }
      table.almanac tbody th, table.almanac tbody td {
        padding: 0.7rem 0.6rem; border-bottom: 1px solid var(--hair); vertical-align: baseline;
      }
      table.almanac tbody tr:nth-child(even) { background: var(--stripe); }
      table.almanac tbody th[scope="row"] {
        text-align: left; font-weight: 700; font-size: 1.05rem; white-space: nowrap;
      }
      .day-date {
        display: block; font-family: ui-sans-serif, system-ui, sans-serif;
        font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--ink-soft);
      }
      .condition { display: flex; align-items: center; gap: 0.55rem; }
      .condition svg { color: var(--accent); flex: none; }
      .condition span { font-style: italic; }
      td.num { font-size: 1.15rem; font-weight: 700; }
      td.num .u { font-size: 0.7rem; font-weight: 400; color: var(--ink-soft); }
      /* Colophon */
      .colophon {
        margin-top: 2.4rem; padding-top: 1rem; border-top: 3px double var(--rule);
        display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem;
        align-items: baseline; justify-content: space-between;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.72rem; letter-spacing: 0.06em; color: var(--ink-soft);
      }
      .colophon a { color: var(--ink); font-weight: 600; text-underline-offset: 3px; }
      .colophon a:focus-visible, table.almanac a:focus-visible {
        outline: 3px solid var(--accent); outline-offset: 2px;
      }
      :focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }
      @media (max-width: 760px) {
        .edition { grid-template-columns: 1fr; gap: 1.6rem; }
      }
      @media (prefers-reduced-motion: reduce) {
        * { transition-duration: 0.01ms !important; }
      }
  body
    -
      function glyph(summary) {
        var s = (summary || '').toLowerCase();
        var snow = "<svg width='18' height='18' viewBox='0 0 18 18' aria-hidden='true' focusable='false' fill='none' stroke='currentColor' stroke-width='1.3' stroke-linecap='round'><path d='M9 2v14M2.5 5l13 8M15.5 5l-13 8'/><path d='M9 5.4 7.6 4M9 5.4 10.4 4M9 12.6 7.6 14M9 12.6 10.4 14'/></svg>";
        var cloud = "<svg width='18' height='18' viewBox='0 0 18 18' aria-hidden='true' focusable='false' fill='none' stroke='currentColor' stroke-width='1.3' stroke-linejoin='round'><path d='M5 13h8a3 3 0 0 0 .3-6A4.2 4.2 0 0 0 5.2 6.4 3.3 3.3 0 0 0 5 13z'/></svg>";
        var suncloud = "<svg width='18' height='18' viewBox='0 0 18 18' aria-hidden='true' focusable='false' fill='none' stroke='currentColor' stroke-width='1.3' stroke-linecap='round' stroke-linejoin='round'><circle cx='7' cy='6.5' r='2.4'/><path d='M7 1.6v1.4M7 10v1.2M2.2 6.5h1.3M10.5 6.5h1.3M3.4 2.9l1 1M10.6 2.9l-1 1'/><path d='M6 15h7a2.6 2.6 0 0 0 .2-5.2A3.6 3.6 0 0 0 6.6 9 2.9 2.9 0 0 0 6 15z'/></svg>";
        var sun = "<svg width='18' height='18' viewBox='0 0 18 18' aria-hidden='true' focusable='false' fill='none' stroke='currentColor' stroke-width='1.3' stroke-linecap='round'><circle cx='9' cy='9' r='3.4'/><path d='M9 1v2.2M9 14.8V17M1 9h2.2M14.8 9H17M3.3 3.3l1.6 1.6M13.1 13.1l1.6 1.6M14.7 3.3l-1.6 1.6M4.9 13.1l-1.6 1.6'/></svg>";
        var blaze = "<svg width='18' height='18' viewBox='0 0 18 18' aria-hidden='true' focusable='false' fill='none' stroke='currentColor' stroke-width='1.3' stroke-linecap='round' stroke-linejoin='round'><path d='M9 1.5c2.2 2.6 3.6 4.7 3.6 7a3.6 3.6 0 1 1-7.2 0c0-1.3.5-2.5 1.4-3.6.3 1 .9 1.6 1.6 1.8C8.4 5.6 8.2 3.7 9 1.5z'/></svg>";
        if (/freezing|bracing|chilly/.test(s)) return snow;
        if (/cool|mild/.test(s)) return cloud;
        if (/warm|balmy/.test(s)) return suncloud;
        if (/sweltering|scorching/.test(s)) return blaze;
        if (/hot/.test(s)) return sun;
        return cloud;
      }
      function parseDate(value) {
        var m = /^(\d{4})-(\d{2})-(\d{2})/.exec(String(value));
        return m ? new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3])) : null;
      }
      var published = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

    a.skip-link(href="#forecast") Skip to the forecast
    .paper
      header.masthead(role="banner")
        p.masthead__kicker Established 2026 · Express &amp; Redis Edition
        h1.masthead__title The Aspire #[em Almanac]
        p.masthead__sub Five-day weather forecast &amp; outlook
        hr.rule-double(aria-hidden="true")
        .dateline
          span Published #{published}
          span(aria-hidden="true")
            != glyph('mild')
          span Prognostications for the week ahead
      main
        .edition
          section.forecast(id="forecast", aria-labelledby="forecast-cap")
            table.almanac
              caption(id="forecast-cap") Forecast for the coming days
              thead
                tr
                  th(scope="col") Day
                  th(scope="col") Conditions
                  th.num(scope="col") °C
                  th.num(scope="col") °F
              tbody
                each forecast in forecasts
                  - var d = parseDate(forecast.date)
                  - var weekday = d ? d.toLocaleDateString('en-US', { weekday: 'long' }) : ''
                  - var datestr = d ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : forecast.date
                  tr
                    th(scope="row")
                      = weekday
                      span.day-date= datestr
                    td
                      .condition
                        != glyph(forecast.summary)
                        span= forecast.summary
                    td.num
                      = forecast.temperatureC
                      span.u °
                    td.num
                      = forecast.temperatureF
                      span.u °
          aside.aside
            section.lead
              h2 From the editor's desk
              p.standfirst Sample readings are conjured at random by the weather service and tucked into a Redis cache for thirty seconds, so two visits within the half-minute will report the very same skies. Refresh after the cache expires for a fresh prognostication.
            section.key
              h2 Reading the glyphs
              ul
                li
                  != glyph('Freezing')
                  span
                    b Frost.&nbsp;
                    | Freezing, bracing or chilly.
                li
                  != glyph('Cool')
                  span
                    b Overcast.&nbsp;
                    | Cool and mild days.
                li
                  != glyph('Warm')
                  span
                    b Bright spells.&nbsp;
                    | Warm and balmy.
                li
                  != glyph('Scorching')
                  span
                    b Heatwave.&nbsp;
                    | Sweltering and scorching.
      footer.colophon(role="contentinfo")
        span Server-rendered with Pug &amp; Express · Aspire weather sample
        span
          a(href="https://aspire.dev", target="_blank", rel="noopener noreferrer") aspire.dev
          | &nbsp;&middot;&nbsp;
          a(href="https://github.com/dotnet/aspire", target="_blank", rel="noopener noreferrer") github.com/dotnet/aspire
